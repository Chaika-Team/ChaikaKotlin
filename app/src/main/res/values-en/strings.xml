    <string name="faqs_title">Frequently asked questions</string>
    <string name="faqs_question_trip_add">How do I add a new trip?</string>
    <string name="faqs_answer_trip_add">Tap \"Add trip\" on the main screen, enter the trip name, and confirm creation.</string>
    <string name="faqs_question_trip_finish">How do I finish a trip?</string>
    <string name="faqs_answer_trip_finish">In the \"Trips\" section, select the active trip and tap \"FINISH TRIP\". This saves all trip data.</string>
    <string name="faqs_question_product_add">How do I add a product to the cart?</string>
    <string name="faqs_answer_product_add">In the \"Products\" section, find the product and tap \"+\" next to it. The product is added to the cart automatically.</string>
    <string name="faqs_question_trip_history">Where can I see trip history?</string>
    <string name="faqs_answer_trip_history">In the \"Trips\" section, scroll down to \"History\". All completed trips are shown there.</string>
    <string name="faqs_question_personal_data">How do I edit personal data?</string>
    <string name="faqs_answer_personal_data">Go to \"Profile\" -> \"Personal data\". There you can view and update your data when needed.</string>
    <string name="faqs_question_app_loading">What should I do if the app does not load?</string>
    <string name="faqs_answer_app_loading">Check your internet connection. If the problem persists, restart the app or clear the cache in settings.</string>
    <string name="faqs_question_logout">How do I log out?</string>
    <string name="faqs_answer_logout">In the \"Profile\" section, tap \"Log out\" at the top of the screen. This ends the current session.</string>
    <string name="faqs_question_offline">Is offline mode supported?</string>
    <string name="faqs_answer_offline">Yes, the app supports offline mode. Data will be synchronized when the internet connection is restored.</string>
    <string name="faqs_not_found_title">Did not find an answer?</string>
    <string name="faqs_not_found_description">If you have additional questions, use the \"Feedback\" section to contact support.</string>
